# ============================================================================
# PANTHEON SYNTHETIC NEWSROOM — Complete Environment Configuration
# ============================================================================

# ============================================================================
# FRONTEND (NEXT_PUBLIC_* are embedded in client bundle)
# ============================================================================

NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SSE_ENABLED=true
NEXT_PUBLIC_POLLING_ARTICLES_MS=3000
NEXT_PUBLIC_POLLING_INSIGHTS_MS=5000
NEXT_PUBLIC_POLLING_SETTINGS_MS=10000

# ============================================================================
# BACKEND: ANTHROPIC API
# ============================================================================

# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-v7-your_key_here

# Claude model to use
# Options: claude-3-haiku-20240307 (faster, cheaper)
#          claude-3-5-sonnet-20241022 (higher quality)
ANTHROPIC_MODEL=claude-3-haiku-20240307

# ============================================================================
# BACKEND: DATABASE
# ============================================================================

# Prisma Database
# Local SQLite: file:./data/pantheon.db
# PostgreSQL: postgresql://user:pass@localhost:5432/pantheon
# Supabase: postgresql://postgres:[PASSWORD]@db.[SUPABASE_URL].supabase.co:5432/postgres
DATABASE_URL=file:./data/pantheon.db

# ============================================================================
# BACKEND: WORDPRESS/CMS INTEGRATION
# ============================================================================

# Mock WordPress (local development)
WP_URL=http://localhost:3000/api/mock-wordpress
WP_USERNAME=admin
WP_APP_PASSWORD=mock_password_here

# For production WordPress.com or self-hosted WordPress:
# WP_URL=https://your-site.com/wp-json/wp/v2/posts
# WP_USERNAME=your_username
# WP_APP_PASSWORD=your_app_password_from_wordpress_security

# Optional: Ghost CMS integration (alternative to WordPress)
# GHOST_API_URL=https://your-ghost-site.com/ghost/api/v3/admin
# GHOST_API_KEY=your_ghost_admin_api_key

# ============================================================================
# BACKEND: CACHING & DEDUPLICATION
# ============================================================================

# Vercel KV (Redis) configuration for production
# Leave empty for local in-memory deduplication
KV_REST_API_TOKEN=
KV_REST_API_URL=

# URL deduplication TTL (seconds)
# 7 days = 604800 seconds
DEDUP_TTL=604800

# ============================================================================
# BACKEND: SCHEDULING & RSS FEEDS
# ============================================================================

# Cron schedule for automatic pipeline execution
# Format: "minute hour day month dayOfWeek"
# Examples:
#   "*/10 * * * *"  = Every 10 minutes (demo)
#   "0 */4 * * *"   = Every 4 hours (production)
#   "0 9,17 * * *"  = At 9am and 5pm daily
CRON_SCHEDULE=0 */4 * * *

# Enable automatic scheduling (set to true for production)
ENABLE_SCHEDULER=false

# RSS feed sources (URLs, newline or comma-separated)
RSS_FEEDS=https://rss.kompas.com/rss/properti.xml,https://www.detik.com/properti/rss,https://ekonomi.bisnis.com/feed

# ============================================================================
# BACKEND: CONTENT CONFIGURATION
# ============================================================================

# Target niche for news ingestion and filtering
TARGET_NICHE=Indonesian property real estate

# Brands to generate content for (comma-separated)
# gen-z-tech: Energetic, conversational tone for younger audiences
# formal-biz: Formal, professional tone for executives and investors
BRANDS=gen-z-tech,formal-biz

# Require manual review before publishing (true for manual workflow)
REQUIRE_REVIEW=false

# ============================================================================
# BACKEND: OBSERVABILITY & LOGGING
# ============================================================================

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# Enable detailed pipeline debugging
DEBUG_PIPELINE=false

# External logging service (optional)
# DATADOG_API_KEY=your_datadog_api_key
# DATADOG_SERVICE_NAME=pantheon-newsroom
# SENTRY_DSN=https://your@sentry.io/123456

# ============================================================================
# BACKEND: RATE LIMITING & SECURITY
# ============================================================================

# API rate limiting window (milliseconds)
RATE_LIMIT_WINDOW_MS=60000

# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# ============================================================================
# DEPLOYMENT & ENVIRONMENT
# ============================================================================

# Environment: development | staging | production
ENVIRONMENT=development

# Vercel-specific configuration
# VERCEL=true
# VERCEL_ENV=production
# VERCEL_GIT_COMMIT_SHA=abc123def456
# VERCEL_URL=pantheon-newsroom.vercel.app

# Expose detailed error messages (dev only!)
EXPOSE_ERRORS_IN_RESPONSE=true